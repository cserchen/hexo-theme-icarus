// Hides visible text while keeping it accessible to screen readers
// http://www.zeldman.com/2012/03/01/replacing-the-9999px-hack-new-image-replacement/
hide-text()
  text-indent: 100%
  white-space: nowrap
  overflow: hidden

// Absolutely centres an element of known dimensions within its positioned parent
absolute-center(width, height = width)
  width: width
  height: height
  position: absolute
  top: 50%
  left: 50%
  margin-top: width * -0.5
  margin-left: height * -0.5

// Prevents a column or page break inside the element (cross-browser)
avoid-column-break()
  vendor("column-break-inside", avoid, only: webkit)
  page-break-inside: avoid
  overflow: hidden
  break-inside: avoid-column
